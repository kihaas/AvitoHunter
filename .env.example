# ── Telegram ──────────────────────────────────────────────
# Токен бота — получить у @BotFather
BOT_TOKEN=1234567890:ABCdef...

# Твой Telegram ID — узнать у @userinfobot
ADMIN_ID=123456789

# ── AI (OpenRouter) ────────────────────────────────────────
# Зарегистрируйся на openrouter.ai — карту привязывать НЕ нужно для бесплатных моделей
OPENROUTER_API_KEY=sk-or-v1-...

# Бесплатные vision-модели (раскомментируй нужную):
# AI_MODEL=qwen/qwen2.5-vl-72b-instruct:free     ← лучший выбор
# AI_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free
# AI_MODEL=mistralai/mistral-small-3.1-24b-instruct:free
# AI_MODEL=openrouter/free                        ← случайная бесплатная с vision
AI_MODEL=qwen/qwen2.5-vl-72b-instruct:free

# ── Настройки поиска ───────────────────────────────────────
MAX_PRICE=12000
CHECK_INTERVAL_MINUTES=30

# ── Прочее ────────────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=data/hunter.db
